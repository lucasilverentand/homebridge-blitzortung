{
  "pluginAlias": "Blitzortung",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "required": ["latitude", "longitude", "mqttHost"],
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Lightning",
        "minLength": 1
      },
      "latitude": {
        "title": "Latitude",
        "type": "number",
        "minimum": -90,
        "maximum": 90,
        "required": true
      },
      "longitude": {
        "title": "Longitude",
        "type": "number",
        "minimum": -180,
        "maximum": 180,
        "required": true
      },
      "radiusKm": {
        "title": "Detection Radius (km)",
        "type": "number",
        "default": 25,
        "minimum": 1,
        "maximum": 500
      },
      "strikeAlertSeconds": {
        "title": "Strike Alert Duration (seconds)",
        "type": "integer",
        "default": 30,
        "minimum": 1,
        "maximum": 3600
      },
      "stormClearMinutes": {
        "title": "Storm Clear Duration (minutes)",
        "type": "integer",
        "default": 30,
        "minimum": 1,
        "maximum": 1440
      },
      "mqttHost": {
        "title": "MQTT Relay Host",
        "type": "string",
        "minLength": 1,
        "required": true
      },
      "mqttPort": {
        "title": "MQTT Relay Port",
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      },
      "mqttTls": {
        "title": "Use TLS",
        "type": "boolean",
        "default": false
      },
      "mqttUsername": {
        "title": "MQTT Username",
        "type": "string"
      },
      "mqttPasswordEnvironmentVariable": {
        "title": "MQTT Password Environment Variable",
        "type": "string",
        "description": "Name of an environment variable containing the MQTT password."
      },
      "topicPrefix": {
        "title": "MQTT Topic Prefix",
        "type": "string",
        "default": "blitzortung/1.1"
      },
      "camera": {
        "title": "Lightning Map Camera",
        "type": "object",
        "properties": {
          "enabled": {
            "title": "Enable Camera",
            "type": "boolean",
            "default": false,
            "description": "Add a HomeKit camera showing the configured detection radius and recent lightning strikes."
          },
          "name": {
            "title": "Camera Name",
            "type": "string",
            "default": "Lightning Map",
            "minLength": 1
          },
          "zoom": {
            "title": "Map Zoom",
            "type": "integer",
            "default": 9,
            "minimum": 1,
            "maximum": 18
          },
          "strikeHistoryMinutes": {
            "title": "Strike History (minutes)",
            "type": "integer",
            "default": 60,
            "minimum": 1,
            "maximum": 1440
          },
          "refreshSeconds": {
            "title": "Map Refresh (seconds)",
            "type": "integer",
            "default": 10,
            "minimum": 5,
            "maximum": 300
          },
          "tileUrlTemplate": {
            "title": "Map Tile URL",
            "type": "string",
            "default": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
            "description": "HTTP(S) tile template containing {z}, {x}, and {y}."
          },
          "tileAttribution": {
            "title": "Map Attribution",
            "type": "string",
            "default": "© OpenStreetMap contributors",
            "minLength": 1
          },
          "tileUserAgent": {
            "title": "Tile Request User Agent",
            "type": "string",
            "default": "homebridge-blitzortung/0.2.1 (+https://github.com/lucasilverentand/homebridge-blitzortung)",
            "minLength": 1
          },
          "tileCacheDays": {
            "title": "Tile Cache Duration (days)",
            "type": "integer",
            "default": 7,
            "minimum": 7,
            "maximum": 365
          },
          "ffmpegPath": {
            "title": "Custom FFmpeg Path",
            "type": "string",
            "description": "Optional. Leave empty to use the FFmpeg binary bundled with the plugin."
          }
        }
      }
    }
  },
  "layout": [
    "name",
    {
      "key": "location",
      "type": "fieldset",
      "title": "Location",
      "expandable": true,
      "expanded": true,
      "items": ["latitude", "longitude", "radiusKm"]
    },
    {
      "key": "alerts",
      "type": "fieldset",
      "title": "Alerts",
      "expandable": true,
      "expanded": true,
      "items": ["strikeAlertSeconds", "stormClearMinutes"]
    },
    {
      "key": "mqtt",
      "type": "fieldset",
      "title": "Blitzortung MQTT Relay",
      "expandable": true,
      "expanded": true,
      "items": [
        "mqttHost",
        "mqttPort",
        "mqttTls",
        "mqttUsername",
        "mqttPasswordEnvironmentVariable",
        "topicPrefix"
      ]
    },
    {
      "key": "cameraSettings",
      "type": "fieldset",
      "title": "Lightning Map Camera",
      "expandable": true,
      "expanded": true,
      "items": [
        "camera.enabled",
        "camera.name",
        "camera.zoom",
        "camera.strikeHistoryMinutes",
        "camera.refreshSeconds",
        "camera.tileUrlTemplate",
        "camera.tileAttribution",
        "camera.tileUserAgent",
        "camera.tileCacheDays",
        "camera.ffmpegPath"
      ]
    }
  ]
}
